            <tbody id="g1-body"></tbody>
        </table>
        <div class="tokki-footer">
            <div class="tokki-footer-label">特記事項　— 第1群</div>
            <textarea id="tokki_g1" placeholder="第1群（身体機能・起居動作）に関する特記事項を入力…"></textarea>
        </div>
    </div>

    <!-- 第2群 -->
