<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>認定調査チェックシート</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;600&family=Noto+Serif+JP:wght@400;600&display=swap');

        :root {
            --bg: #f4f1eb;
            --surface: #faf8f3;
            --surface2: #edeae3;
            --border: #d8d4ca;
            --border-l: #bfbab0;
            --text: #28251e;
            --text-sub: #6a6660;
            --text-dim: #a09c94;
            --accent: #3a5070;
            --accent-h: #2c3e58;
            --gold: #7a5e28;
            --gold-bg: rgba(122, 94, 40, 0.07);
            --gold-bd: rgba(122, 94, 40, 0.22);
            --sel-bg: #dce6f0;
            --sel-border: #6a90b0;
            --sel-text: #1e3a58;
            --row-hover: rgba(0, 0, 0, 0.025);
            --tokki-bg: rgba(122, 94, 40, 0.05);
            --tokki-border: rgba(122, 94, 40, 0.25);
            --radius: 6px;
            --radius-s: 4px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Noto Sans JP', sans-serif;
            font-weight: 400;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            padding: 24px 20px 48px;
            font-size: 14px;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        /* HEADER */
        header {
            max-width: 1200px;
            margin: 0 auto 28px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
        }

        .header-title {
            display: flex;
            align-items: baseline;
            gap: 14px;
            flex-wrap: wrap;
        }

        .header-title h1 {
            font-family: 'Noto Serif JP', serif;
            font-size: 1.35rem;
            font-weight: 600;
            color: var(--text);
            letter-spacing: .06em;
        }

        .header-title span {
            font-size: .78rem;
            color: var(--text-dim);
            letter-spacing: .04em;
        }

        .header-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            align-items: center;
        }

        .btn {
            padding: 7px 16px;
            border-radius: var(--radius-s);
            font-family: inherit;
            font-size: .78rem;
            font-weight: 500;
            cursor: pointer;
            transition: all .18s;
            letter-spacing: .03em;
            border: 1px solid transparent;
        }

        .btn-ghost {
            background: transparent;
            border-color: var(--border-l);
            color: var(--text-sub);
        }

        .btn-ghost:hover {
            border-color: var(--accent);
            color: var(--accent-h);
        }

        .btn-gold {
            background: var(--gold-bg);
            border-color: var(--gold-bd);
            color: var(--gold);
        }

        .btn-gold:hover {
            background: rgba(122, 94, 40, .13);
        }

        /* BASIC INFO */
        .card {
            max-width: 1200px;
            margin: 0 auto 20px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px 24px;
        }

        .basic-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 14px 18px;
        }

        .field label {
            display: block;
            font-size: .72rem;
            color: var(--text-dim);
            letter-spacing: .06em;
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        .field input,
        .field select {
            width: 100%;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: var(--radius-s);
            padding: 7px 10px;
            font-family: inherit;
            font-size: .88rem;
            color: var(--text);
            outline: none;
            transition: border-color .18s;
        }

        .field input:focus,
        .field select:focus {
            border-color: var(--accent);
        }

        .field select option {
            background: #fff;
        }

        /* TABS */
        .tabs-wrap {
            max-width: 1200px;
            margin: 0 auto 16px;
            display: flex;
            gap: 2px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 4px;
            flex-wrap: wrap;
        }

        .tab-btn {
            padding: 7px 14px;
            border: none;
            border-radius: var(--radius-s);
            background: transparent;
            font-family: inherit;
            font-size: .78rem;
            font-weight: 500;
            color: var(--text-sub);
            cursor: pointer;
            transition: all .18s;
            letter-spacing: .03em;
            white-space: nowrap;
        }

        .tab-btn:hover {
            color: var(--text);
            background: var(--surface2);
        }

        .tab-btn.active {
            background: var(--surface2);
            color: var(--accent-h);
            border: 1px solid var(--border-l);
        }

        /* PANEL */
        .group-panel {
            display: none;
            max-width: 1200px;
            margin: 0 auto 20px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
        }

        .group-panel.active {
            display: block;
        }

        .group-header {
            padding: 13px 22px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .group-header-no {
            font-size: .7rem;
            font-weight: 600;
            color: var(--gold);
            background: var(--gold-bg);
            border: 1px solid var(--gold-bd);
            padding: 2px 8px;
            border-radius: 2px;
            letter-spacing: .05em;
        }

        .group-header-name {
            font-family: 'Noto Serif JP', serif;
            font-size: .92rem;
            font-weight: 600;
            color: var(--text);
            letter-spacing: .06em;
        }

        /* TABLE */
        .survey-table {
            width: 100%;
            border-collapse: collapse;
        }

        .survey-table thead th {
            padding: 8px 14px;
            font-size: .7rem;
            font-weight: 500;
            color: var(--text-dim);
            background: var(--surface2);
            border-bottom: 1px solid var(--border);
            letter-spacing: .08em;
            text-align: left;
            white-space: nowrap;
        }

        .survey-table thead th.center {
            text-align: center;
        }

        .data-row td {
            padding: 10px 14px;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
            transition: background .12s;
        }

        .data-row:hover td {
            background: var(--row-hover);
        }

        .item-no {
            display: inline-block;
            font-size: .7rem;
            font-weight: 600;
            color: var(--text-dim);
            letter-spacing: .06em;
            min-width: 36px;
        }

        .item-name {
            font-size: .88rem;
            color: var(--text);
        }

        .item-sub {
            font-size: .72rem;
            color: var(--text-dim);
            margin-top: 2px;
        }

        /* RADIO */
        .radio-group {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
            align-items: center;
        }

        .radio-option input[type="radio"] {
            display: none;
        }

        .radio-option label {
            display: inline-block;
            padding: 4px 11px;
            border: 1px solid var(--border);
            border-radius: 2px;
            cursor: pointer;
            font-size: .76rem;
            color: var(--text-sub);
            transition: all .15s;
            white-space: nowrap;
            letter-spacing: .02em;
        }

        .radio-option label:hover {
            border-color: var(--border-l);
            color: var(--text);
        }

        .radio-option input:checked+label {
            background: var(--sel-bg);
            border-color: var(--sel-border);
            color: var(--sel-text);
        }

        /* CHECKBOX */
        .check-wrap {
            display: flex;
            justify-content: center;
        }

        .check-label {
            display: flex;
            align-items: center;
            gap: 7px;
            cursor: pointer;
            font-size: .78rem;
            color: var(--text-sub);
        }

        .check-label input[type="checkbox"] {
            width: 15px;
            height: 15px;
            accent-color: var(--accent);
            cursor: pointer;
        }

        /* 各群末尾の特記事項欄 */
        .tokki-footer {
            padding: 14px 22px;
            border-top: 1px solid var(--tokki-border);
            background: var(--tokki-bg);
        }

        .tokki-footer-label {
            font-size: .72rem;
            font-weight: 600;
            color: var(--gold);
            letter-spacing: .08em;
            margin-bottom: 7px;
        }

        .tokki-footer textarea {
            width: 100%;
            background: #fff;
            border: 1px solid var(--tokki-border);
            border-radius: var(--radius-s);
            padding: 9px 12px;
            font-family: inherit;
            font-size: .85rem;
            color: var(--text);
            resize: vertical;
            min-height: 72px;
            outline: none;
            transition: border-color .18s;
            line-height: 1.7;
        }

        .tokki-footer textarea:focus {
            border-color: var(--gold);
        }

        .tokki-footer textarea::placeholder {
            color: var(--text-dim);
            font-size: .8rem;
        }

        /* 第7群サブヘッダ */
        .sub-divider td {
            padding: 8px 14px;
            font-size: .7rem;
            color: var(--gold);
            background: var(--gold-bg);
            border-top: 1px solid var(--gold-bd);
            border-bottom: 1px solid var(--gold-bd);
            letter-spacing: .1em;
            font-weight: 600;
        }

        /* PRINT */
        @media print {
            body {
                background: #fff;
                padding: 0;
            }

            .header-actions,
            .tabs-wrap {
                display: none;
            }

            .group-panel {
                display: block !important;
                box-shadow: none;
                margin-bottom: 12px;
            }

            .tokki-footer {
                border: 1px solid #bbb;
            }
        }

        @media(max-width:640px) {
            body {
                padding: 12px 10px 32px;
            }

            .radio-option label {
                padding: 3px 8px;
                font-size: .72rem;
            }

            .survey-table thead th,
            .data-row td {
                padding: 7px 8px;
            }
        }
    </style>
</head>

<body>

    <header>
        <div class="header-title">
            <h1>認定調査チェックシート</h1>
            <span>第1群〜第7群 ／ 群別特記事項</span>
        </div>
        <div class="header-actions">
            <button class="btn btn-ghost" onclick="resetAll()">リセット</button>
            <button class="btn btn-gold" onclick="exportTxt()">テキスト出力</button>
            <button class="btn btn-ghost" onclick="window.print()">印刷</button>
        </div>
    </header>

    <div class="card">
        <div class="basic-grid">
            <div class="field"><label>調査日</label><input type="date" id="surveyDate"></div>
            <div class="field"><label>被保険者番号</label><input type="text" id="insNo" placeholder="—"></div>
            <div class="field"><label>被調査者氏名</label><input type="text" id="name" placeholder="—"></div>
            <div class="field"><label>生年月日</label><input type="date" id="birthday"></div>
            <div class="field"><label>性別</label><select id="gender">
                    <option value="">—</option>
                    <option>男性</option>
                    <option>女性</option>
                </select></div>

        </div>
    </div>

    <div class="tabs-wrap">
        <button class="tab-btn active" onclick="showTab(0)">第1群　身体機能</button>
        <button class="tab-btn" onclick="showTab(1)">第2群　生活機能</button>
        <button class="tab-btn" onclick="showTab(2)">第3群　認知機能</button>
        <button class="tab-btn" onclick="showTab(3)">第4群　精神・行動</button>
        <button class="tab-btn" onclick="showTab(4)">第5群　社会生活</button>
        <button class="tab-btn" onclick="showTab(5)">第6群　医療</button>
