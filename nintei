            { no: "3-9", name: "外出して戻れない", opts: ["ない", "ときどきある", "ある"] },
        ];
        const G4 = [
            { no: "4-1", name: "被害的", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-2", name: "作話", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-3", name: "感情が不安定", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-4", name: "昼夜逆転", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-5", name: "同じ話をする", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-6", name: "大声をだす", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-7", name: "介護に抵抗", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-8", name: "落ち着きなし", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-9", name: "一人で出たがる", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-10", name: "収集癖", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-11", name: "物や衣類を壊す", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-12", name: "ひどい物忘れ", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-13", name: "独り言・独り笑い", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-14", name: "自分勝手に行動する", opts: ["ない", "ときどきある", "ある"] },
            { no: "4-15", name: "話がまとまらない", opts: ["ない", "ときどきある", "ある"] },
        ];
        const G5 = [
            { no: "5-1", name: "薬の内服", opts: ["介助されていない", "一部介助", "全介助"] },
            { no: "5-2", name: "金銭の管理", opts: ["介助されていない", "一部介助", "全介助"] },
            { no: "5-3", name: "日常の意思決定", opts: ["できる", "特別困難でない毎日の決定はできる", "日常的に困難", "できない"] },
            { no: "5-4", name: "集団への不適応", opts: ["ない", "ときどきある", "ある"] },
            { no: "5-5", name: "買い物", opts: ["できる", "できない"] },
            { no: "5-6", name: "簡単な調理", opts: ["できる", "できない"] },
        ];
        const G6 = ["点滴の管理", "中心静脈栄養", "透析", "ストーマ（人工肛門）の処置", "酸素療法", "レスピレーター（人工呼吸器）", "気管切開の処置", "疼痛の看護", "経管栄養", "モニター測定（血圧・心拍・酸素飽和度等）", "褥瘡の処置", "カテーテル（コンドームカテーテル・留置・ウロストーマ等）"];
        const G7K = [
            { rank: "自立", desc: "障害等を認めない状態。" },
            { rank: "J1", desc: "交通機関を利用して外出する。" },
            { rank: "J2", desc: "隣近所へなら外出する。" },
            { rank: "A1", desc: "介助により外出し、日中はほとんどベッドから離れて生活する。" },
            { rank: "A2", desc: "外出頻度が少なく、日中も寝たりおきたりの生活をしている。" },
            { rank: "B1", desc: "車いすに移乗し、食事・排泄はベッドから離れて行う。" },
            { rank: "B2", desc: "介助により車いすに移乗する。" },
            { rank: "C1", desc: "日中もベッド上で過ごし、自力で寝返りをうつ。" },
            { rank: "C2", desc: "日中もベッド上で過ごし、自力では寝返りもうてない。" },
        ];
        const G7N = [
            { rank: "自立", desc: "認知症なし。" },
            { rank: "Ⅰ", desc: "日常生活は家庭内及び社会的にほぼ自立している。" },
            { rank: "Ⅱa", desc: "家庭外で日常生活に支障をきたすような症状・行動がある。" },
            { rank: "Ⅱb", desc: "家庭内でも日常生活に支障をきたすような症状・行動がある。" },
            { rank: "Ⅲa", desc: "日中を中心として介護を必要とする症状・行動がある。" },
            { rank: "Ⅲb", desc: "夜間を中心として介護を必要とする症状・行動がある。" },
            { rank: "Ⅳ", desc: "常に介護を必要とするような症状・行動が頻繁に見られる。" },
            { rank: "M", desc: "著しい精神症状・問題行動あるいは重篤な身体疾患があり専門医療を必要とする。" },
        ];

        function buildRadio(items, tbodyId) {
            const tbody = document.getElementById(tbodyId);
            items.forEach(item => {
                const key = `${tbodyId}_${item.no}`;
                const opts = item.opts.map((o, i) =>
                    `<div class="radio-option"><input type="radio" name="${key}" id="${key}_${i}" value="${o}"><label for="${key}_${i}">${o}</label></div>`
                ).join('');
                const tr = document.createElement('tr');
                tr.className = 'data-row';
                tr.innerHTML = `
      <td><span class="item-no">${item.no}</span></td>
      <td><div class="item-name">${item.name}</div>${item.sub ? `<div class="item-sub">${item.sub}</div>` : ''}</td>
      <td><div class="radio-group">${opts}</div></td>`;
                tbody.appendChild(tr);
            });
        }

        function buildG6() {
            const tbody = document.getElementById('g6-body');
            G6.forEach((name, i) => {
                const no = `6-${i + 1}`;
                const tr = document.createElement('tr');
                tr.className = 'data-row';
                tr.innerHTML = `
      <td><span class="item-no">${no}</span></td>
      <td class="item-name">${name}</td>
      <td><div class="check-wrap"><label class="check-label"><input type="checkbox" id="chk_g6_${i}"><span>実施あり</span></label></div></td>`;
                tbody.appendChild(tr);
            });
        }

        function buildG7() {
            const tbody = document.getElementById('g7-body');
            const dH = document.createElement('tr'); dH.className = 'sub-divider';
            dH.innerHTML = `<td colspan="3">障害老人の日常生活自立度（寝たきり度）</td>`; tbody.appendChild(dH);
            G7K.forEach((item, i) => {
                const tr = document.createElement('tr'); tr.className = 'data-row';
                tr.innerHTML = `
      <td><span class="item-no">${item.rank}</span></td>
      <td style="font-size:.82rem;color:var(--text-sub)">${item.desc}</td>
      <td style="text-align:center"><label class="check-label" style="justify-content:center"><input type="radio" name="g7_k" id="g7k_${i}" value="${item.rank}"><span style="font-size:.75rem">該当</span></label></td>`;
                tbody.appendChild(tr);
            });
            const dN = document.createElement('tr'); dN.className = 'sub-divider';
            dN.innerHTML = `<td colspan="3">認知症高齢者の日常生活自立度</td>`; tbody.appendChild(dN);
            G7N.forEach((item, i) => {
                const tr = document.createElement('tr'); tr.className = 'data-row';
                tr.innerHTML = `
      <td><span class="item-no">${item.rank}</span></td>
      <td style="font-size:.82rem;color:var(--text-sub)">${item.desc}</td>
      <td style="text-align:center"><label class="check-label" style="justify-content:center"><input type="radio" name="g7_n" id="g7n_${i}" value="${item.rank}"><span style="font-size:.75rem">該当</span></label></td>`;
                tbody.appendChild(tr);
            });
        }

        function showTab(idx) {
            document.querySelectorAll('.group-panel').forEach((p, i) => p.classList.toggle('active', i === idx));
            document.querySelectorAll('.tab-btn').forEach((b, i) => b.classList.toggle('active', i === idx));
        }

        function resetAll() {
            if (!confirm('すべての入力をリセットしますか？')) return;
            document.querySelectorAll('input[type=radio]').forEach(r => r.checked = false);
            document.querySelectorAll('input[type=checkbox]').forEach(c => c.checked = false);
            document.querySelectorAll('textarea').forEach(t => t.value = '');
            document.querySelectorAll('input[type=text],input[type=date]').forEach(i => i.value = '');
            document.getElementById('gender').value = '';
            document.getElementById('surveyDate').value = new Date().toISOString().split('T')[0];
        }

        function exportTxt() {
            const pad = (s, n) => String(s).padEnd(n, '　');
            const hr = (n = 60) => '─'.repeat(n);
            const lines = [];
            const surveyDate = document.getElementById('surveyDate').value || '未入力';
            const name = document.getElementById('name').value || '未入力';
            const insNo = document.getElementById('insNo').value || '未入力';
            const birthday = document.getElementById('birthday').value || '未入力';
            const gender = document.getElementById('gender').value || '未入力';
            const investigator = document.getElementById('investigator').value || '未入力';

            lines.push('');
            lines.push('　　認定調査チェックシート');
            lines.push('');
            lines.push(hr());
            lines.push(`  調査日　　　  : ${surveyDate}`);
            lines.push(`  被保険者番号  : ${insNo}`);
            lines.push(`  被調査者氏名  : ${name}　（${gender}）`);
            lines.push(`  生年月日　　  : ${birthday}`);

            lines.push(hr());
            lines.push('');

            const sections = [
                { label: '第1群　身体機能・起居動作', items: G1, id: 'g1-body', tokki: 'tokki_g1' },
                { label: '第2群　生活機能', items: G2, id: 'g2-body', tokki: 'tokki_g2' },
                { label: '第3群　認知機能', items: G3, id: 'g3-body', tokki: 'tokki_g3' },
                { label: '第4群　精神・行動障害', items: G4, id: 'g4-body', tokki: 'tokki_g4' },
                { label: '第5群　社会生活への適応', items: G5, id: 'g5-body', tokki: 'tokki_g5' },
            ];

            sections.forEach(sec => {
                lines.push(`【${sec.label}】`);
                lines.push(hr(50));
                sec.items.forEach(item => {
                    const key = `${sec.id}_${item.no}`;
                    const sel = document.querySelector(`input[name="${key}"]:checked`);
                    lines.push(`  ${pad(item.no, 6)} ${pad(item.name, 22)} →  ${sel ? sel.value : '（未選択）'}`);
                });
                const note = document.getElementById(sec.tokki)?.value.trim();
                if (note) lines.push('', `  ［特記事項］`, `  ${note.replace(/\n/g, '\n  ')}`);
                lines.push('');
            });

            lines.push('【第6群　過去14日間に受けた特別な医療】');
            lines.push(hr(50));
            G6.forEach((name, i) => {
                const chk = document.getElementById(`chk_g6_${i}`);
                lines.push(`  ${pad(`6-${i + 1}`, 6)} ${pad(name, 30)} →  ${chk && chk.checked ? '実施あり' : '実施なし'}`);
            });
            const n6 = document.getElementById('tokki_g6')?.value.trim();
            if (n6) lines.push('', `  ［特記事項］`, `  ${n6.replace(/\n/g, '\n  ')}`);
            lines.push('');

            lines.push('【第7群　日常生活自立度】');
            lines.push(hr(50));
            const selK = document.querySelector('input[name="g7_k"]:checked');
            const selN = document.querySelector('input[name="g7_n"]:checked');
            lines.push(`  障害老人　寝たきり度　 →  ${selK ? selK.value : '（未選択）'}`);
            lines.push(`  認知症　日常生活自立度 →  ${selN ? selN.value : '（未選択）'}`);
            const n7 = document.getElementById('tokki_g7')?.value.trim();
            if (n7) lines.push('', `  ［特記事項］`, `  ${n7.replace(/\n/g, '\n  ')}`);
            lines.push('');
            lines.push(hr());
            lines.push(`  出力日時 : ${new Date().toLocaleString('ja-JP')}`);
            lines.push('');

            const blob = new Blob([lines.join('\n')], { type: 'text/plain;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url; a.download = `認定調査_${name.replace(/\s/g, '')}_${surveyDate}.txt`; a.click();
            URL.revokeObjectURL(url);
        }

        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('surveyDate').value = new Date().toISOString().split('T')[0];
            buildRadio(G1, 'g1-body');
            buildRadio(G2, 'g2-body');
            buildRadio(G3, 'g3-body');
            buildRadio(G4, 'g4-body');
            buildRadio(G5, 'g5-body');
            buildG6();
            buildG7();
        });
    </script>
